# Arbiter configuration
# Copy this file to .env and fill in your values
# After starting postgres: docker compose up -d postgres
# Then run: alembic upgrade head

# === Database ===
DATABASE_URL=postgresql+asyncpg://arbiter:arbiter@localhost/arbiter
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
# Default port 5432 if omitted. Use the docker-compose defaults above for local dev.

# === Notifications ===
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
# Create at: Discord Server Settings -> Integrations -> Webhooks

# === Detection Thresholds (optional — defaults shown) ===
LONGSHOT_PRICE_MIN=0.75
LONGSHOT_PRICE_MAX=0.95
LONGSHOT_LIQUIDITY_MIN=1000.0
LONGSHOT_COOLDOWN_HOURS=24.0
TIME_DECAY_PRICE_MIN=0.80
TIME_DECAY_PRICE_MAX=0.97
TIME_DECAY_LIQUIDITY_MIN=500.0
TIME_DECAY_HOURS_TO_EXPIRY_MAX=72.0
TIME_DECAY_COOLDOWN_HOURS=12.0

# === Logging ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG for troubleshooting; INFO for normal operation
